<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.bloodlust</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="BS_Bloodlust"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="BS_Bloodlust"]/exclusionTags</xpath>
          <value><li>RBP_BloodlustDistressed</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="BS_Bloodlust"]</xpath>
          <value><exclusionTags><li>RBP_BloodlustDistressed</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.hemogen</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="VU_GreaterHemogenDrain"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="VU_GreaterHemogenDrain"]/exclusionTags</xpath>
          <value><li>HemogenDrain</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="VU_GreaterHemogenDrain"]</xpath>
          <value><exclusionTags><li>HemogenDrain</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.deathless</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="BS_ReturningSoul"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="BS_ReturningSoul"]/exclusionTags</xpath>
          <value><li>RBP_Deathless</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="BS_ReturningSoul"]</xpath>
          <value><exclusionTags><li>RBP_Deathless</li></exclusionTags></value>
        </nomatch>
      </li>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="BS_Immortal"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="BS_Immortal"]/exclusionTags</xpath>
          <value><li>RBP_Deathless</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="BS_Immortal"]</xpath>
          <value><exclusionTags><li>RBP_Deathless</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>bigsmall.madscience</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="BS_MadScienceField"]/prerequisites[not(li="GunTurrets")]</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/ResearchProjectDef[defName="BS_MadScienceField"]/prerequisites</xpath>
          <value><li>GunTurrets</li></value>
        </match>
      </li>
      <li Class="PatchOperationRemove">
        <xpath>Defs/ThingDef/researchPrerequisites[li="GunTurrets"][li="BS_MadScienceField"]/li[.="GunTurrets"]</xpath>
      </li>
      <li Class="PatchOperationRemove">
        <xpath>Defs/ThingDef/recipeMaker/researchPrerequisites[li="GunTurrets"][li="BS_MadScienceField"]/li[.="GunTurrets"]</xpath>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>bigsmall.geneintegrator</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="BS_GeneGeneIntegrator"]</xpath>
        <match Class="PatchOperationSequence">
          <operations>
            <li Class="PatchOperationAdd">
              <xpath>Defs/ThingDef[defName="BS_GeneGeneIntegrator"]</xpath>
              <value>
                <recipeMaker>
                  <researchPrerequisite>BS_ArchiteGeneScience</researchPrerequisite>
                  <researchPrerequisites>
                    <li>Archogenetics</li>
                  </researchPrerequisites>
                </recipeMaker>
                <statBases>
                  <MarketValue>4000</MarketValue>
                  <WorkToMake>6000</WorkToMake>
                </statBases>
              </value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>Defs/ThingDef[defName="BS_GeneGeneIntegrator"]/costList</xpath>
              <value>
                <costList Inherit="False">
                  <ArchiteCapsule>1</ArchiteCapsule>
                  <MedicineUltratech>2</MedicineUltratech>
                  <ComponentSpacer>2</ComponentSpacer>
                  <Neutroamine>20</Neutroamine>
                </costList>
              </value>
            </li>
          </operations>
        </match>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.claws</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="LoS_VenomTalons"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="LoS_VenomTalons"]/exclusionTags</xpath>
          <value><li>RBP_Claws</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="LoS_VenomTalons"]</xpath>
          <value><exclusionTags><li>RBP_Claws</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.bleedrate</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="BS_SlowBleeding"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="BS_SlowBleeding"]/exclusionTags</xpath>
          <value><li>RBP_BleedRate</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="BS_SlowBleeding"]</xpath>
          <value><exclusionTags><li>RBP_BleedRate</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.flirty</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="BS_NotFlirty"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="BS_NotFlirty"]/exclusionTags</xpath>
          <value><li>RBP_Flirt</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="BS_NotFlirty"]</xpath>
          <value><exclusionTags><li>RBP_Flirt</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

</Patch>
