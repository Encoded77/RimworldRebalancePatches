  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>cyberneticsresearch.mind</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybSurgicalImplantation"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods>
            <li>moistestwhale.gitscyberbrains</li>
          </mods>
          <match Class="PatchOperationSequence">
            <operations>
              <li Class="PatchOperationConditional">
                <xpath>Defs/ThingDef[defName="RBP_EchoSeerCyberbrain"]</xpath>
                <match Class="PatchOperationAdd">
                  <xpath>Defs/ThingDef[defName="RBP_EchoSeerCyberbrain"]</xpath>
                  <value>
                    <recipeMaker>
                      <researchPrerequisite>RBP_CybEchoCyberbrains</researchPrerequisite>
                    </recipeMaker>
                  </value>
                </match>
              </li>
              <li Class="PatchOperationConditional">
                <xpath>Defs/ThingDef[defName="RBP_EchoOracleCyberbrain"]</xpath>
                <match Class="PatchOperationAdd">
                  <xpath>Defs/ThingDef[defName="RBP_EchoOracleCyberbrain"]</xpath>
                  <value>
                    <recipeMaker>
                      <researchPrerequisite>RBP_CybEchoOracle</researchPrerequisite>
                    </recipeMaker>
                  </value>
                </match>
              </li>
            </operations>
          </match>
        </match>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>cyberneticsresearch.mind</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybSurgicalImplantation"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods>
            <li>hlx.ultratechalteredcarbon</li>
          </mods>
          <match Class="PatchOperationSequence">
            <operations>

              <!-- The one authored node in this lane -->
              <li Class="PatchOperationAdd">
                <xpath>Defs</xpath>
                <value>
                  <ResearchProjectDef>
                    <defName>RBP_CybCorticalStacks</defName>
                    <label>cortical stacks</label>
                    <description>Recording a mind is one problem; running it in a body that was never its own is the harder one. This is the science of the resleeve: the matrix that holds a stack, the connector that reads it, and the procedures for duplicating, wiping and rebinding a person who is now a file.</description>
                    <baseCost>6000</baseCost>
                    <techLevel>Ultra</techLevel>
                    <tab>RBP_CyberneticsTab</tab>
                    <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
                    <requiredResearchFacilities>
                      <li>MultiAnalyzer</li>
                    </requiredResearchFacilities>
                    <prerequisites>
                      <li>AC_NeuralDigitalization</li>
                    </prerequisites>
                    <researchViewX>25</researchViewX>
                    <researchViewY>3.40</researchViewY>
                  </ResearchProjectDef>
                </value>
              </li>

              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralDigitalization"]/label</xpath>
                <value><label>neural digitisation</label></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralDigitalization"]/description</xpath>
                <value><description>A mind is a pattern, and a pattern can be recorded. A blank cortical stack seated at the top of the spine copies a person as they live; a cache keeps the copy once they die.</description></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralDigitalization"]/baseCost</xpath>
                <value><baseCost>5000</baseCost></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralDigitalization"]/prerequisites</xpath>
                <value>
                  <prerequisites>
                    <li>RBP_CybSurgicalImplantation</li>
                  </prerequisites>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralDigitalization"]</xpath>
                <value>
                  <tab>RBP_CyberneticsTab</tab>
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralDigitalization"]/researchViewX</xpath>
                <value><researchViewX>24</researchViewX></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralDigitalization"]/researchViewY</xpath>
                <value><researchViewY>3.40</researchViewY></value>
              </li>

              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralEditing"]/label</xpath>
                <value><label>neural editing</label></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralEditing"]/description</xpath>
                <value><description>Once a person is a file, the file can be opened: duplicated, cut, wiped, or handed to someone else. The benches are ordinary, but the decision to use them is not.</description></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralEditing"]/baseCost</xpath>
                <value><baseCost>5000</baseCost></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralEditing"]/prerequisites</xpath>
                <value>
                  <prerequisites>
                    <li>RBP_CybCorticalStacks</li>
                  </prerequisites>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralEditing"]</xpath>
                <value>
                  <tab>RBP_CyberneticsTab</tab>
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralEditing"]/researchViewX</xpath>
                <value><researchViewX>26</researchViewX></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralEditing"]/researchViewY</xpath>
                <value><researchViewY>3.40</researchViewY></value>
              </li>

              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralCasting"]/label</xpath>
                <value><label>needlecasting</label></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralCasting"]/description</xpath>
                <value><description>A stacked mind can be transmitted. Needlecasting throws a consciousness down a psychic subwave carrier into a waiting remote body hundreds of tiles away; the body left behind keeps breathing on life support and nothing else. Relays extend the reach.</description></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralCasting"]/baseCost</xpath>
                <value><baseCost>5500</baseCost></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralCasting"]/prerequisites</xpath>
                <value>
                  <prerequisites>
                    <li>RBP_CybCorticalStacks</li>
                  </prerequisites>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralCasting"]</xpath>
                <value>
                  <tab>RBP_CyberneticsTab</tab>
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralCasting"]/researchViewX</xpath>
                <value><researchViewX>26</researchViewX></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_NeuralCasting"]/researchViewY</xpath>
                <value><researchViewY>4.20</researchViewY></value>
              </li>

              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SleeveGestation"]/label</xpath>
                <value><label>sleeve gestation</label></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SleeveGestation"]/description</xpath>
                <value><description>A recorded mind needs a body to wear. Sleeves are blank bodies grown to order in a gestator, as good or poor as the genetic stock poured into the vat. Grow your own and you stop depending on who happens to have died recently.</description></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SleeveGestation"]/baseCost</xpath>
                <value><baseCost>5000</baseCost></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SleeveGestation"]/prerequisites</xpath>
                <value>
                  <prerequisites>
                    <li>AC_NeuralDigitalization</li>
                  </prerequisites>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>Defs/ResearchProjectDef[defName="AC_SleeveGestation"]</xpath>
                <value>
                  <tab>RBP_CyberneticsTab</tab>
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SleeveGestation"]/researchViewX</xpath>
                <value><researchViewX>25</researchViewX></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SleeveGestation"]/researchViewY</xpath>
                <value><researchViewY>2.60</researchViewY></value>
              </li>

              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SkilltrainerProduction"]/label</xpath>
                <value><label>neural trainers</label></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SkilltrainerProduction"]/description</xpath>
                <value><description>A stacked mind can be made to practise: drop a recorded person into a virtual task ten thousand times and harvest the neural pattern as a skilltrainer, ready to hand to someone who never did the work. The minds used are not asked.</description></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SkilltrainerProduction"]/baseCost</xpath>
                <value><baseCost>4500</baseCost></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SkilltrainerProduction"]/prerequisites</xpath>
                <value>
                  <prerequisites>
                    <li>RBP_CybCorticalStacks</li>
                  </prerequisites>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>Defs/ResearchProjectDef[defName="AC_SkilltrainerProduction"]</xpath>
                <value>
                  <tab>RBP_CyberneticsTab</tab>
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SkilltrainerProduction"]/researchViewX</xpath>
                <value><researchViewX>26</researchViewX></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_SkilltrainerProduction"]/researchViewY</xpath>
                <value><researchViewY>5.00</researchViewY></value>
              </li>

              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_PsytrainerProduction"]/label</xpath>
                <value><label>neural trainers: psytrainers</label></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_PsytrainerProduction"]/description</xpath>
                <value><description>The same process turned on a psycaster: a psychic ability is a learned shape, and a mind held in that shape long enough presses into a psytrainer. Cheap only because the hard part was solved next door.</description></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_PsytrainerProduction"]/baseCost</xpath>
                <value><baseCost>2000</baseCost></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_PsytrainerProduction"]/prerequisites</xpath>
                <value>
                  <prerequisites>
                    <li>AC_SkilltrainerProduction</li>
                  </prerequisites>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>Defs/ResearchProjectDef[defName="AC_PsytrainerProduction"]</xpath>
                <value>
                  <tab>RBP_CyberneticsTab</tab>
                </value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_PsytrainerProduction"]/researchViewX</xpath>
                <value><researchViewX>26</researchViewX></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ResearchProjectDef[defName="AC_PsytrainerProduction"]/researchViewY</xpath>
                <value><researchViewY>5.80</researchViewY></value>
              </li>

              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="AC_NeuralMatrix"]/researchPrerequisites/li[text()="AC_NeuralDigitalization"]</xpath>
                <value><li>RBP_CybCorticalStacks</li></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="AC_NeuralConnector"]/researchPrerequisites/li[text()="AC_NeuralDigitalization"]</xpath>
                <value><li>RBP_CybCorticalStacks</li></value>
              </li>

              <!-- The editor buildings follow the mechanic they serve. -->
              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="AC_NeuralEditor"]/researchPrerequisites/li[text()="AC_NeuralDigitalization"]</xpath>
                <value><li>AC_NeuralEditing</li></value>
              </li>

              <li Class="PatchOperationAdd">
                <xpath>Defs/RecipeDef[defName="AC_DuplicateNeuralStack"]</xpath>
                <value>
