  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>cyberneticsresearch.mind</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="AC_CompactNeuralEditor"]/researchPrerequisites/li[text()="AC_NeuralDigitalization"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods>
            <li>hlx.ultratechalteredcarbon</li>
          </mods>
          <match Class="RebalancePatches.PatchOperationFindModById">
            <mods>
              <li>vanillaexpanded.gravship</li>
            </mods>
            <match Class="PatchOperationConditional">
              <xpath>Defs/ResearchProjectDef[defName="RBP_CybSurgicalImplantation"]</xpath>
              <match Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="AC_CompactNeuralEditor"]/researchPrerequisites/li[text()="AC_NeuralDigitalization"]</xpath>
                <value><li>AC_NeuralEditing</li></value>
              </match>
            </match>
          </match>
        </match>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>cyberneticsresearch.mind</settingKey>
    <operations>
      <li Class="RebalancePatches.PatchOperationFindModById">
        <mods>
          <li>ludeon.rimworld.royalty</li>
        </mods>
        <match Class="PatchOperationAdd">
          <xpath>Defs/ResearchProjectDef[defName="RBP_CybEchoFusionCore" or defName="RBP_CybEchoSuppression" or defName="RBP_CybEchoOracle"]</xpath>
          <value>
            <techprintCount>1</techprintCount>
            <techprintCommonality>1</techprintCommonality>
            <techprintMarketValue>2000</techprintMarketValue>
            <heldByFactionCategoryTags>
              <li>Empire</li>
            </heldByFactionCategoryTags>
          </value>
        </match>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>cyberneticsresearch.mind</settingKey>
    <operations>

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybEnhancedCyberbrain"]</xpath>
        <match Class="PatchOperationReplace">
          <xpath>Defs/ResearchProjectDef[defName="AC_NeuralDigitalization"]/prerequisites</xpath>
          <value>
            <prerequisites>
              <li>RBP_CybEnhancedCyberbrain</li>
            </prerequisites>
          </value>
        </match>
      </li>

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBasicCyberbrain"]</xpath>
        <match Class="PatchOperationReplace">
          <xpath>Defs/ResearchProjectDef[defName="RBP_CybEchoNeuralRegulation"]/prerequisites</xpath>
          <value>
            <prerequisites>
              <li>RBP_CybBasicCyberbrain</li>
            </prerequisites>
          </value>
        </match>
      </li>

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybCorticalStacks"]</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/ResearchProjectDef[defName="RBP_CybSyntheticAscension" or defName="RBP_CybSymbioticIntegration"]/prerequisites</xpath>
          <value>
            <li>RBP_CybCorticalStacks</li>
          </value>
        </match>
      </li>

      <li Class="PatchOperationRemove">
        <xpath>Defs/ResearchProjectDef[(defName="RBP_CybSyntheticAscension" or defName="RBP_CybSymbioticIntegration") and (prerequisites/li="RBP_CybArchotechCybernetics" or prerequisites/li="RBP_CybCorticalStacks")]/prerequisites/li[text()="RBP_CybSurgicalImplantation"]</xpath>
      </li>

    </operations>
  </Operation>

</Patch>
