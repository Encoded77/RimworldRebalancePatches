              <li Class="PatchOperationAdd">
                <xpath>Defs/RecipeDef[defName="AC_WipeActiveNeuralStack"]</xpath>
                <value>
                  <researchPrerequisites>
                    <li>RBP_CybCorticalStacks</li>
                  </researchPrerequisites>
                </value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>Defs/RecipeDef[defName="AC_UnboundPersona"]</xpath>
                <value>
                  <researchPrerequisites>
                    <li>RBP_CybCorticalStacks</li>
