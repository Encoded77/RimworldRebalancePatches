<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>cyberneticsresearch.mind</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybSurgicalImplantation"]</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs</xpath>
          <value>

            <ResearchProjectDef>
              <defName>RBP_CybEchoNeuralRegulation</defName>
              <label>Echo neural regulation</label>
              <description>Echo's entry line: heat sinks, entropy dampers, a one-shot surge valve and a meditation aid. None of it makes a psycaster stronger; all of it keeps one from burning out.</description>
              <baseCost>2400</baseCost>
              <techLevel>Spacer</techLevel>
              <tab>RBP_CyberneticsTab</tab>
              <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
              <prerequisites>
                <li>RBP_CybSurgicalImplantation</li>
              </prerequisites>
              <researchViewX>23</researchViewX>
              <researchViewY>0.80</researchViewY>
            </ResearchProjectDef>

            <ResearchProjectDef>
              <defName>RBP_CybEchoPsyfocusSystems</defName>
              <label>Echo psyfocus systems</label>
              <description>Echo's second line spends less focus per cast: a recycling capacitor shaves the cost off every cast, a resistance lattice halves it at the price of the caster's own meditation, a cost suppressor halves it and lets neural heat run hot instead. Three answers to one problem, none of them free.</description>
              <baseCost>3000</baseCost>
              <techLevel>Spacer</techLevel>
              <tab>RBP_CyberneticsTab</tab>
              <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
              <prerequisites>
                <li>RBP_CybEchoNeuralRegulation</li>
              </prerequisites>
              <researchViewX>24</researchViewX>
              <researchViewY>0.80</researchViewY>
            </ResearchProjectDef>

            <ResearchProjectDef>
              <defName>RBP_CybEchoCyberbrains</defName>
              <label>Echo cyberbrains</label>
              <description>Echo does not build general-purpose brains. A SEER replaces the psychic architecture of a mind with hardware built for it: entropy sheds faster, the focus band runs wider, and casting steadies without the caster having to be steady. It is a worse brain than a Civis or an Aegis at everything else, and its buyers have never cared.</description>
              <baseCost>4500</baseCost>
              <techLevel>Ultra</techLevel>
              <tab>RBP_CyberneticsTab</tab>
              <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
              <requiredResearchFacilities>
                <li>MultiAnalyzer</li>
              </requiredResearchFacilities>
              <prerequisites>
                <li>RBP_CybEchoPsyfocusSystems</li>
              </prerequisites>
              <researchViewX>25</researchViewX>
              <researchViewY>0.80</researchViewY>
            </ResearchProjectDef>

            <ResearchProjectDef>
              <defName>RBP_CybEchoOracle</defName>
              <label>Echo ORACLE</label>
              <description>The house's flagship, and the furthest anyone has taken a mind toward being a psychic instrument. An ORACLE rebuilds the psychic architecture almost end to end and carries extra cortex capacity for the hardware that hangs off it. Echo never solved what the rebuild costs elsewhere: an ORACLE wearer is a formidable psycaster and a noticeably more fragile person.</description>
              <baseCost>6000</baseCost>
              <techLevel>Ultra</techLevel>
              <tab>RBP_CyberneticsTab</tab>
              <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
              <requiredResearchFacilities>
                <li>MultiAnalyzer</li>
              </requiredResearchFacilities>
              <prerequisites>
                <li>RBP_CybEchoCyberbrains</li>
              </prerequisites>
              <researchViewX>26</researchViewX>
              <researchViewY>0.80</researchViewY>
            </ResearchProjectDef>

            <ResearchProjectDef>
              <defName>RBP_CybEchoSensitivityAmplifier</defName>
              <label>Echo sensitivity amplifier</label>
              <description>Raw psychic sensitivity, driven upward. It is crude, painful, and the single largest stat swing in the psychic catalogue, which is why Echo sells it apart and does not advertise it.</description>
              <baseCost>4500</baseCost>
              <techLevel>Ultra</techLevel>
              <tab>RBP_CyberneticsTab</tab>
              <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
              <requiredResearchFacilities>
                <li>MultiAnalyzer</li>
              </requiredResearchFacilities>
              <prerequisites>
                <li>RBP_CybEchoPsyfocusSystems</li>
              </prerequisites>
              <researchViewX>25</researchViewX>
              <researchViewY>1.60</researchViewY>
            </ResearchProjectDef>

            <ResearchProjectDef>
              <defName>RBP_CybEchoFusionCore</defName>
              <label>Echo fusion core</label>
              <description>Two devices that manufacture psychic energy rather than manage it. A caged fusion core refills focus but cripples heat dissipation; a vicarious meditator earns focus while its owner does something else. Neither is needed to cast; both are pure indulgence.</description>
              <baseCost>8000</baseCost>
              <techLevel>Ultra</techLevel>
              <tab>RBP_CyberneticsTab</tab>
              <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
              <requiredResearchFacilities>
                <li>MultiAnalyzer</li>
              </requiredResearchFacilities>
              <prerequisites>
                <li>RBP_CybEchoSensitivityAmplifier</li>
              </prerequisites>
              <researchViewX>26</researchViewX>
              <researchViewY>1.60</researchViewY>
            </ResearchProjectDef>

            <ResearchProjectDef>
              <defName>RBP_CybEchoSuppression</defName>
              <label>Echo suppression</label>
              <description>The other half of Echo's business: a passivator that all but severs a mind from the psychic field, and a targeter that renders the wearer deaf to drones and soothing emanations alike. Worn by people whose job is to stand in front of a psycaster.</description>
              <baseCost>3500</baseCost>
              <techLevel>Ultra</techLevel>
              <tab>RBP_CyberneticsTab</tab>
              <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
              <requiredResearchFacilities>
                <li>MultiAnalyzer</li>
              </requiredResearchFacilities>
              <prerequisites>
                <li>RBP_CybEchoNeuralRegulation</li>
              </prerequisites>
              <researchViewX>24</researchViewX>
              <researchViewY>0.00</researchViewY>
            </ResearchProjectDef>

          </value>
        </match>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>cyberneticsresearch.mind</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybSurgicalImplantation"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods>
            <li>cedaro.psychicimplant</li>
          </mods>
          <match Class="PatchOperationSequence">
            <operations>

              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="PI_NHSV"]/recipeMaker/researchPrerequisites/li[text()="BrainWiring"]</xpath>
                <value><li>RBP_CybEchoNeuralRegulation</li></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="PI_NHEC"]/recipeMaker/researchPrerequisites/li[text()="NeuralComputation"]</xpath>
                <value><li>RBP_CybEchoNeuralRegulation</li></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="PI_NHRA"]/recipeMaker/researchPrerequisites/li[text()="NeuralComputation"]</xpath>
                <value><li>RBP_CybEchoNeuralRegulation</li></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="PI_AMC"]/recipeMaker/researchPrerequisites/li[text()="NeuralComputation"]</xpath>
                <value><li>RBP_CybEchoNeuralRegulation</li></value>
              </li>

              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="PI_PRC"]/recipeMaker/researchPrerequisites/li[text()="MolecularAnalysis"]</xpath>
                <value><li>RBP_CybEchoPsyfocusSystems</li></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="PI_Resistance"]/recipeMaker/researchPrerequisites/li[text()="NeuralComputation"]</xpath>
                <value><li>RBP_CybEchoPsyfocusSystems</li></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="PI_NHCS"]/recipeMaker/researchPrerequisites/li[text()="NeuralComputation"]</xpath>
                <value><li>RBP_CybEchoPsyfocusSystems</li></value>
              </li>

              <!-- Echo sensitivity amplifier: PsychicSensitivity +0.75, bought with pain. -->
              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="PI_HOPS"]/recipeMaker/researchPrerequisites/li[text()="NeuralComputation"]</xpath>
                <value><li>RBP_CybEchoSensitivityAmplifier</li></value>
              </li>

              <!-- Echo fusion core: the two Hediff.Tick() implants. -->
              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="PI_PFC"]/recipeMaker/researchPrerequisites/li[text()="ShipReactor"]</xpath>
                <value><li>RBP_CybEchoFusionCore</li></value>
              </li>
              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="PI_AMV"]/recipeMaker/researchPrerequisites/li[text()="NeuralComputation"]</xpath>
                <value><li>RBP_CybEchoFusionCore</li></value>
              </li>

              <li Class="PatchOperationReplace">
                <xpath>Defs/ThingDef[defName="PI_TPDD"]/recipeMaker/researchPrerequisites/li[text()="BrainWiring"]</xpath>
                <value><li>RBP_CybEchoSuppression</li></value>
              </li>
              <li Class="PatchOperationAdd">
                <xpath>Defs/ThingDef[defName="PI_Passivator"]/recipeMaker</xpath>
                <value>
                  <researchPrerequisites>
                    <li>RBP_CybEchoSuppression</li>
                  </researchPrerequisites>
                </value>
              </li>

            </operations>
          </match>
        </match>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>cyberneticsresearch.mind</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybSurgicalImplantation"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
