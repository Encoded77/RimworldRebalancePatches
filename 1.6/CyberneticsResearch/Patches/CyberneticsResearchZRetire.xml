  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>cyberneticsresearch.retire</settingKey>
    <operations>

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybSurgicalImplantation"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods><li>vat.epoeforked</li></mods>
          <match Class="PatchOperationRemove">
            <xpath>Defs/ResearchProjectDef[defName="BrainSurgery" or defName="EPOE_AIPersonaCoreImplant"]</xpath>
          </match>
        </match>
      </li>

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybSurgicalImplantation"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods><li>lts.i</li></mods>
          <match Class="PatchOperationRemove">
            <xpath>Defs/ResearchProjectDef[defName="I_ExtraArms" or defName="I_ImplantedExplosives"]</xpath>
          </match>
        </match>
      </li>

      <!-- Body trunk -->

      <!-- EPOE-Forked's own organ, limb and rib line. -->
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBionicOrgans"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods><li>vat.epoeforked</li></mods>
          <match Class="PatchOperationRemove">
            <xpath>Defs/ResearchProjectDef[defName="SurrogateOrgans" or defName="SyntheticOrgans" or defName="AdvancedBionics" or defName="RibReplacements" or defName="EPOE_OrganicOptimizer" or defName="EPOE_SyntheticRepair" or defName="EPOE_NeurologicalTreatment" or defName="EPOE_MAAIChip"]</xpath>
          </match>
        </match>
      </li>

      <!-- EPOE-Forked's Royalty add-on. All three are techprinted; see the file header note. -->
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBionicOrgans"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods><li>vat.epoeforkedroyalty</li></mods>
          <match Class="PatchOperationRemove">
            <xpath>Defs/ResearchProjectDef[defName="EPOE_AdvancedSpecializedLimbs" or defName="EPOE_AdvancedCompactWeaponry" or defName="EPOE_SyntheticOrgansIntegration"]</xpath>
          </match>
        </match>
      </li>

      <!-- Vanilla Royalty implant projects whose content is entirely body-trunk. -->
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBionicOrgans"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods><li>ludeon.rimworld.royalty</li></mods>
          <match Class="PatchOperationRemove">
            <xpath>Defs/ResearchProjectDef[defName="SpecializedLimbs" or defName="CompactWeaponry" or defName="ArtificialMetabolism" or defName="SkinHardening" or defName="HealingFactors" or defName="FleshShaping"]</xpath>
          </match>
        </match>
      </li>

      <!-- Integrated Implants' faceplate project - its one item lands on a body node. -->
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBionicOrgans"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods><li>lts.i</li></mods>
          <match Class="PatchOperationRemove">
            <xpath>Defs/ResearchProjectDef[defName="LTS_BionicFaceplates"]</xpath>
          </match>
        </match>
      </li>

      <!-- Module trunk -->

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybModularCybernetics"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods><li>lts.i</li></mods>
          <match Class="PatchOperationRemove">
            <xpath>Defs/ResearchProjectDef[defName="I_BasicImplants" or defName="I_BasicHormonalImplants" or defName="I_SanguophageImplants" or defName="I_SubdermalArmour" or defName="I_ShoulderTurrets" or defName="I_CranialInsulation" or defName="I_CaptiveControl" or defName="I_Biomimicry" or defName="I_SkillChipPort" or defName="LTS_NeuralHyperacceleration" or defName="LTS_EmergencyImplants" or defName="LTS_FieldManipulationImplants" or defName="LTS_ModularBionics" or defName="LTS_ModularBionicWeaponry" or defName="LTS_ModularBionicWeaponryUltra" or defName="LTS_ModularBionicOptics" or defName="LTS_ModularBionicArms" or defName="LTS_ModularBionicLegs"]</xpath>
          </match>
        </match>
      </li>

      <!-- Vanilla Royalty: circadian influence splits three implants onto utility systems. -->
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybModularCybernetics"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods><li>ludeon.rimworld.royalty</li></mods>
          <match Class="PatchOperationRemove">
            <xpath>Defs/ResearchProjectDef[defName="CircadianInfluence"]</xpath>
          </match>
        </match>
      </li>

      <!-- Altered Carbon 2: the Rogian arm blade is an integral melee module. -->
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybModularCybernetics"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods><li>hlx.ultratechalteredcarbon</li></mods>
          <match Class="PatchOperationRemove">
            <xpath>Defs/ResearchProjectDef[defName="AC_RogianArmaments"]</xpath>
          </match>
        </match>
      </li>

      <!-- Body AND module trunks: content on both sides -->

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBionicOrgans"]</xpath>
        <match Class="PatchOperationConditional">
          <xpath>Defs/ResearchProjectDef[defName="RBP_CybModularCybernetics"]</xpath>
          <match Class="RebalancePatches.PatchOperationFindModById">
            <mods><li>lts.i</li></mods>
            <match Class="PatchOperationRemove">
              <xpath>Defs/ResearchProjectDef[defName="I_BionicTails"]</xpath>
            </match>
          </match>
        </match>
      </li>

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBionicOrgans"]</xpath>
        <match Class="PatchOperationConditional">
          <xpath>Defs/ResearchProjectDef[defName="RBP_CybModularCybernetics"]</xpath>
          <match Class="RebalancePatches.PatchOperationFindModById">
            <mods><li>ludeon.rimworld.royalty</li></mods>
            <match Class="PatchOperationRemove">
              <xpath>Defs/ResearchProjectDef[defName="VenomSynthesis"]</xpath>
            </match>
          </match>
        </match>
      </li>

      <!-- Body AND cyberbrain trunks -->

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBionicOrgans"]</xpath>
        <match Class="PatchOperationConditional">
          <xpath>Defs/ResearchProjectDef[defName="RBP_CybBasicCyberbrain"]</xpath>
          <match Class="RebalancePatches.PatchOperationFindModById">
            <mods><li>vat.epoeforked</li></mods>
            <match Class="PatchOperationRemove">
              <xpath>Defs/ResearchProjectDef[defName="EPOE_Glitterworld_Implants"]</xpath>
            </match>
          </match>
        </match>
      </li>

      <!-- Cyberbrain trunk -->

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBasicCyberbrain"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods><li>hlx.ultratechalteredcarbon</li></mods>
          <match Class="PatchOperationRemove">
            <xpath>Defs/ResearchProjectDef[defName="AC_VocalSynthesis" or defName="AC_MentalFortification" or defName="AC_REMEnchanment"]</xpath>
          </match>
        </match>
      </li>

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBasicCyberbrain"]</xpath>
        <match Class="RebalancePatches.PatchOperationFindModById">
          <mods><li>lts.i</li></mods>
          <match Class="PatchOperationRemove">
            <xpath>Defs/ResearchProjectDef[defName="I_TelecommunicationImplants"]</xpath>
          </match>
        </match>
      </li>

      <!-- Cyberbrain AND mind trunks -->

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBasicCyberbrain"]</xpath>
        <match Class="PatchOperationConditional">
          <xpath>Defs/ResearchProjectDef[defName="RBP_CybEchoNeuralRegulation"]</xpath>
          <match Class="RebalancePatches.PatchOperationFindModById">
            <mods><li>moistestwhale.gitscyberbrains</li></mods>
            <match Class="PatchOperationRemove">
              <xpath>Defs/ResearchProjectDef[defName="gitsResearchMicromachines" or defName="gitsResearchNaniteGrafting" or defName="gitsResearchCyberNetIntegration" or defName="gitsResearchBasicCyberization" or defName="gitsResearchEnhancedCyberization" or defName="gitsResearchSpecializedCyberization" or defName="gitsResearchAdvSpecializedCyberization" or defName="gitsResearchCombatCyberization" or defName="gitsResearchExtremeCyberization"]</xpath>
            </match>
          </match>
        </match>
      </li>

      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybBasicCyberbrain"]</xpath>
        <match Class="PatchOperationConditional">
          <xpath>Defs/ResearchProjectDef[defName="RBP_CybEchoNeuralRegulation"]</xpath>
          <match Class="RebalancePatches.PatchOperationFindModById">
