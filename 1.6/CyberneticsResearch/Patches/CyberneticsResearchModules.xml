<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>cyberneticsresearch.modules</settingKey>
    <operations>
      <li Class="RebalancePatches.PatchOperationIfPresent">
        <xpath>Defs/ResearchProjectDef[defName="RBP_CybSurgicalImplantation"]</xpath>
        <operations>

          <li Class="PatchOperationAdd">
            <xpath>Defs</xpath>
            <value>

              <ResearchProjectDef>
                <defName>RBP_CybModularCybernetics</defName>
                <label>modular cybernetics</label>
                <description>Standardise the inside of an artificial limb or organ. A common mounting rail, a shared power bus and a data channel turn a finished prosthetic into a socket, so hardware can be swapped in and out without rebuilding the part around it.\n\nUnlocks the module bench and the first small modules: eyes that see in the dark or shrug off a flash, a nose that reads a meal before it is eaten, a tongue that enjoys it.</description>
                <baseCost>2200</baseCost>
                <techLevel>Spacer</techLevel>
                <tab>RBP_CyberneticsTab</tab>
                <prerequisites>
                  <li>RBP_CybSurgicalImplantation</li>
                </prerequisites>
                <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
                <researchViewX>9</researchViewX>
                <researchViewY>2.10</researchViewY>
              </ResearchProjectDef>

              <ResearchProjectDef>
                <defName>RBP_CybIntegralMelee</defName>
                <label>integral melee weaponry</label>
                <description>Build blades, claws and fangs that live inside the body. Folded into a forearm, a shin or a jaw, they deploy in a fraction of a second and never have to be drawn, carried or dropped.</description>
                <baseCost>2500</baseCost>
                <techLevel>Spacer</techLevel>
                <tab>RBP_CyberneticsTab</tab>
                <prerequisites>
                  <li>RBP_CybModularCybernetics</li>
                </prerequisites>
                <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
                <researchViewX>10</researchViewX>
                <researchViewY>0.00</researchViewY>
              </ResearchProjectDef>

              <ResearchProjectDef>
                <defName>RBP_CybIntegralRanged</defName>
                <label>integral ranged weaponry</label>
                <description>Fit a barrel where a bone used to be. Arm-mounted guns feed from internal magazines and fire on a nerve impulse, while targeting and telescopic optics turn an eye socket into a fire control system.</description>
                <baseCost>2800</baseCost>
                <techLevel>Spacer</techLevel>
                <tab>RBP_CyberneticsTab</tab>
                <prerequisites>
                  <li>RBP_CybModularCybernetics</li>
                </prerequisites>
                <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
                <researchViewX>10</researchViewX>
                <researchViewY>0.60</researchViewY>
              </ResearchProjectDef>

              <ResearchProjectDef>
                <defName>RBP_CybLocomotionSystems</defName>
                <label>locomotion systems</label>
                <description>Rebuild how a body moves. Reshaped joints, deployable fins and lift assistance change gait rather than strength, letting a colonist cross ground, water and thin air that would otherwise stop them.</description>
                <baseCost>2000</baseCost>
                <techLevel>Spacer</techLevel>
                <tab>RBP_CyberneticsTab</tab>
                <prerequisites>
                  <li>RBP_CybModularCybernetics</li>
                </prerequisites>
                <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
                <researchViewX>10</researchViewX>
                <researchViewY>1.20</researchViewY>
              </ResearchProjectDef>

              <ResearchProjectDef>
                <defName>RBP_CybMetabolicSystems</defName>
                <label>metabolic and environmental systems</label>
                <description>Take the chemistry of survival out of the hands of biology. Stomachs that digest what no one should eat, lungs and kidneys that strip out poison, and ribs that hold a body at its own comfortable temperature whatever the sky is doing.</description>
                <baseCost>2400</baseCost>
                <techLevel>Spacer</techLevel>
                <tab>RBP_CyberneticsTab</tab>
                <prerequisites>
                  <li>RBP_CybModularCybernetics</li>
                </prerequisites>
                <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
                <researchViewX>10</researchViewX>
                <researchViewY>1.80</researchViewY>
              </ResearchProjectDef>

              <ResearchProjectDef>
                <defName>RBP_CybSkillChips</defName>
                <label>skill chips</label>
                <description>Encode practised competence onto a chip and let a nervous system read it back. A chip port sits at the base of the spine; the chips themselves slot into it, and can be pulled and moved to whoever needs the skill this season.\n\nThe rarest chips are found, not made.</description>
                <baseCost>2600</baseCost>
                <techLevel>Spacer</techLevel>
                <tab>RBP_CyberneticsTab</tab>
                <prerequisites>
                  <li>RBP_CybModularCybernetics</li>
                </prerequisites>
                <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
                <researchViewX>10</researchViewX>
                <researchViewY>2.40</researchViewY>
              </ResearchProjectDef>

              <ResearchProjectDef>
                <defName>RBP_CybUtilitySystems</defName>
                <label>utility systems</label>
                <description>The unglamorous hardware that makes a working body work better: bracing that carries a load, tool hands that mine and shape, glands and ribs that dose a colonist with what they need when they need it, and clocks that free a person from the night.</description>
                <baseCost>1500</baseCost>
                <techLevel>Industrial</techLevel>
                <tab>RBP_CyberneticsTab</tab>
                <prerequisites>
                  <li>RBP_CybModularCybernetics</li>
                </prerequisites>
                <researchViewX>10</researchViewX>
                <researchViewY>3.00</researchViewY>
              </ResearchProjectDef>

              <ResearchProjectDef>
                <defName>RBP_CybDefensiveSystems</defName>
                <label>defensive systems</label>
                <description>Armour that cannot be taken off. Plating grown under the skin, hardened dermal glands, and emergency systems that fire a shield, seal a breach or smother a fire in the instant before it matters.</description>
                <baseCost>3000</baseCost>
                <techLevel>Spacer</techLevel>
                <tab>RBP_CyberneticsTab</tab>
                <prerequisites>
                  <li>RBP_CybModularCybernetics</li>
                </prerequisites>
                <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
                <researchViewX>10</researchViewX>
                <researchViewY>3.60</researchViewY>
              </ResearchProjectDef>

              <ResearchProjectDef>
                <defName>RBP_CybFieldManipulation</defName>
                <label>field manipulation</label>
                <description>Project something other than matter. Implanted emitters bend light around their host, hold a shield bubble at arm's length, or feed a lock exactly the biometric signature it was waiting for.</description>
                <baseCost>4000</baseCost>
                <techLevel>Spacer</techLevel>
                <tab>RBP_CyberneticsTab</tab>
                <prerequisites>
                  <li>RBP_CybModularCybernetics</li>
                </prerequisites>
                <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
                <researchViewX>10</researchViewX>
                <researchViewY>4.20</researchViewY>
              </ResearchProjectDef>

              <ResearchProjectDef>
                <defName>RBP_CybUltratechWeaponModules</defName>
                <label>ultratech weapon modules</label>
                <description>The top of the integral weapons line: monofilament wire, contained plasma, lattice-grown talons and gravitic strikes. Each is built at the edge of what can be held together, and worth more than the arm it is fitted to.</description>
                <baseCost>6000</baseCost>
                <techLevel>Ultra</techLevel>
                <tab>RBP_CyberneticsTab</tab>
                <prerequisites>
                  <li>RBP_CybIntegralMelee</li>
                  <li>RBP_CybIntegralRanged</li>
                </prerequisites>
                <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
                <researchViewX>11</researchViewX>
                <researchViewY>0.30</researchViewY>
              </ResearchProjectDef>

            </value>
