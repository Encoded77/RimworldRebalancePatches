              <operations>

                <li Class="PatchOperationAdd">
                  <xpath>Defs</xpath>
                  <value>
                    <ResearchProjectDef>
                      <defName>RBP_CybAnomalousGrafting</defName>
                      <label>anomalous grafting</label>
                      <description>The surgery for seating things a body was never meant to hold, like bioferrite and dead-life residue, and for keeping the host standing while the flesh learns to tolerate them.</description>
                      <baseCost>800</baseCost>
                      <techLevel>Industrial</techLevel>
                      <tab>RBP_CyberneticsTab</tab>
                      <prerequisites>
                        <li>Prosthetics</li>
                      </prerequisites>
                      <researchViewX>2</researchViewX>
                      <researchViewY>6.20</researchViewY>
                    </ResearchProjectDef>
                  </value>
                </li>

                <li Class="PatchOperationAdd">
                  <xpath>Defs/ResearchProjectDef[defName="LTS_AdvancedGhoulEnhancements" or defName="DreadheartRegeneration" or defName="PsychicAgonizer" or defName="BlacksightDevice" or defName="MetalhorrorSymbiont" or defName="HyperalkalaicArchites" or defName="PsychicBeguiler" or defName="HulkificationSurgery" or defName="HyperAdrenalineGland" or defName="DefensiveImpaler" or defName="DeadlifeCoil" or defName="SlayersCollar" or defName="StalkerizingSurgery" or defName="NullificationLobotomy" or defName="DroneLobotomy" or defName="PsychicSustainer" or defName="AnalgesialLobotomy"]/prerequisites</xpath>
                  <value>
                    <li>RBP_CybAnomalousGrafting</li>
                  </value>
                </li>

