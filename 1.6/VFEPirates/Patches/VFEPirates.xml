<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>vfepirates.chargeweapons</settingKey>
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VFEP_Box_ChargeLance" or defName="VFEP_Box_ChargeBlaster"]/researchPrerequisites</xpath>
        <value>
          <researchPrerequisites Inherit="False">
            <li>ChargedShot</li>
            <li>VFEP_SpacerWarcasketWeaponry</li>
          </researchPrerequisites>
        </value>
      </li>
      <li Class="RebalancePatches.PatchOperationFindModById">
        <mods>
          <li>vanillaexpanded.vwec</li>
        </mods>
        <match Class="PatchOperationReplace">
          <xpath>Defs/ThingDef[defName="VFEP_Box_Railgun"]/researchPrerequisites</xpath>
          <value>
            <researchPrerequisites Inherit="False">
              <li>VWE_MassDrivers</li>
              <li>VFEP_SpacerWarcasketWeaponry</li>
            </researchPrerequisites>
          </value>
        </match>
      </li>
      <li Class="RebalancePatches.PatchOperationFindModById">
        <mods>
          <li>danzinagri.warcasketweaponquality</li>
        </mods>
        <match Class="PatchOperationSequence">
          <operations>
            <li Class="PatchOperationConditional">
              <xpath>Defs/ThingDef[defName="VFEP_WarcasketGun_Railgun"]</xpath>
              <match Class="PatchOperationAdd">
                <xpath>Defs/ThingDef[defName="VFEP_WarcasketGun_Railgun"]</xpath>
                <value>
                  <recipeMaker>
                    <researchPrerequisites>
                      <li>VWE_MassDrivers</li>
                      <li>VFEP_SpacerWarcasketWeaponry</li>
                    </researchPrerequisites>
                  </recipeMaker>
                </value>
              </match>
            </li>
            <li Class="PatchOperationAdd">
              <xpath>Defs/ThingDef[defName="VFEP_WarcasketGun_ChargeLance" or defName="VFEP_WarcasketGun_ChargeBlaster"]/recipeMaker</xpath>
              <value>
                <researchPrerequisites>
                  <li>ChargedShot</li>
                </researchPrerequisites>
              </value>
            </li>
          </operations>
        </match>
      </li>
    </operations>
  </Operation>
  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>vfepirates.empirescenario</settingKey>
    <operations>
      <li Class="RebalancePatches.PatchOperationFindModById">
        <mods>
          <li>ludeon.rimworld.royalty</li>
        </mods>
        <match Class="PatchOperationAdd">
          <xpath>Defs/FactionDef[defName="Empire"]/permanentEnemyToEveryoneExcept</xpath>
          <value>
            <li>VFEP_PlayerPirate</li>
          </value>
        </match>
      </li>
    </operations>
  </Operation>
</Patch>