<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>vanilla.toxicmeat</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/ThingDef[defName="Hopper"]/building/defaultStorageSettings/filter/disallowedThingDefs</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/ThingDef[defName="Hopper"]/building/defaultStorageSettings/filter/disallowedThingDefs</xpath>
          <value>
            <li>VAEWaste_ToxicMeat</li>
          </value>
        </match>
      </li>
      <li Class="PatchOperationAdd">
        <xpath>Defs/RecipeDef[@Name="CookMealBase"]/defaultIngredientFilter/disallowedThingDefs</xpath>
        <value>
          <li>VAEWaste_ToxicMeat</li>
        </value>
      </li>
    </operations>
  </Operation>

</Patch>
