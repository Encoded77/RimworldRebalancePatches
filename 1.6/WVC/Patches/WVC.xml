      <li Class="PatchOperationReplace">
        <xpath>Defs/XenotypeDef[defName="WVC_GeneThrower"]/factionlessGenerationWeight</xpath>
        <value><factionlessGenerationWeight>0</factionlessGenerationWeight></value>
