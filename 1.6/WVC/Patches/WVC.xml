<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.psychic</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="PsychicAbility_Dull"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="PsychicAbility_Dull"]/exclusionTags</xpath>
          <value>
            <li>WVC_PsychicSunSensitivityDeaf</li>
            <li>WVC_PsychicMoonSensitivityDeaf</li>
          </value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="PsychicAbility_Dull"]</xpath>
          <value>
            <exclusionTags>
              <li>WVC_PsychicSunSensitivityDeaf</li>
              <li>WVC_PsychicMoonSensitivityDeaf</li>
            </exclusionTags>
          </value>
        </nomatch>
      </li>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="PsychicAbility_Deaf"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="PsychicAbility_Deaf"]/exclusionTags</xpath>
          <value>
            <li>WVC_PsychicSunSensitivityDeaf</li>
            <li>WVC_PsychicMoonSensitivityDeaf</li>
          </value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="PsychicAbility_Deaf"]</xpath>
          <value>
            <exclusionTags>
              <li>WVC_PsychicSunSensitivityDeaf</li>
              <li>WVC_PsychicMoonSensitivityDeaf</li>
            </exclusionTags>
          </value>
        </nomatch>
      </li>
    </operations>
  </Operation>
