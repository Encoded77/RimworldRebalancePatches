  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>xenotypes.wvcchances</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/FactionDef[defName="PirateYttakin"]/xenotypeSet/xenotypeChances/WVC_Featherdust</xpath>
        <match Class="PatchOperationRemove">
          <xpath>Defs/FactionDef[defName="PirateYttakin"]/xenotypeSet/xenotypeChances/WVC_Featherdust</xpath>
        </match>
      </li>
      <li Class="PatchOperationConditional">
        <xpath>Defs/FactionDef[defName="Beggars"]/xenotypeSet/xenotypeChances/WVC_CatDeity</xpath>
        <match Class="PatchOperationRemove">
          <xpath>Defs/FactionDef[defName="Beggars"]/xenotypeSet/xenotypeChances/WVC_CatDeity</xpath>
        </match>
      </li>
      <li Class="PatchOperationConditional">
        <xpath>Defs/FactionDef[defName="Beggars"]/xenotypeSet/xenotypeChances/WVC_Blank</xpath>
        <match Class="PatchOperationRemove">
          <xpath>Defs/FactionDef[defName="Beggars"]/xenotypeSet/xenotypeChances/WVC_Blank</xpath>
        </match>
      </li>
      <li Class="RebalancePatches.PatchOperationFindModById">
        <mods>
          <li>ludeon.rimworld.anomaly</li>
        </mods>
        <match Class="PatchOperationSequence">
          <operations>
            <li Class="PatchOperationConditional">
              <xpath>Defs/FactionDef[defName="OutlanderCivil"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              <match Class="PatchOperationRemove">
                <xpath>Defs/FactionDef[defName="OutlanderCivil"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              </match>
            </li>
            <li Class="PatchOperationConditional">
              <xpath>Defs/FactionDef[defName="TribeRough"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              <match Class="PatchOperationRemove">
                <xpath>Defs/FactionDef[defName="TribeRough"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              </match>
            </li>
            <li Class="PatchOperationConditional">
              <xpath>Defs/FactionDef[defName="TribeCivil"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              <match Class="PatchOperationRemove">
                <xpath>Defs/FactionDef[defName="TribeCivil"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              </match>
            </li>
            <li Class="PatchOperationConditional">
              <xpath>Defs/FactionDef[defName="PirateWaster"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              <match Class="PatchOperationRemove">
                <xpath>Defs/FactionDef[defName="PirateWaster"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              </match>
            </li>
            <li Class="PatchOperationConditional">
              <xpath>Defs/FactionDef[defName="Empire"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              <match Class="PatchOperationRemove">
                <xpath>Defs/FactionDef[defName="Empire"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              </match>
            </li>
            <li Class="PatchOperationConditional">
              <xpath>Defs/FactionDef[defName="Beggars"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              <match Class="PatchOperationRemove">
                <xpath>Defs/FactionDef[defName="Beggars"]/xenotypeSet/xenotypeChances/WVC_Undead</xpath>
              </match>
            </li>
            <li Class="PatchOperationConditional">
              <xpath>Defs/FactionDef[defName="HoraxCult"]/xenotypeSet</xpath>
              <match Class="PatchOperationAdd">
                <xpath>Defs/FactionDef[defName="HoraxCult"]/xenotypeSet/xenotypeChances</xpath>
                <value>
                  <WVC_Undead>0.2</WVC_Undead>
                </value>
              </match>
              <nomatch Class="PatchOperationAdd">
                <xpath>Defs/FactionDef[defName="HoraxCult"]</xpath>
                <value>
                  <xenotypeSet Inherit="False">
                    <xenotypeChances>
                      <WVC_Undead>0.2</WVC_Undead>
                    </xenotypeChances>
                  </xenotypeSet>
                </value>
              </nomatch>
            </li>
            <li Class="PatchOperationConditional">
              <xpath>Defs/FactionDef[defName="TribeSavageImpid"]/xenotypeSet/xenotypeChances/WVC_Sandycat</xpath>
              <match Class="PatchOperationRemove">
                <xpath>Defs/FactionDef[defName="TribeSavageImpid"]/xenotypeSet/xenotypeChances/WVC_Sandycat</xpath>
              </match>
            </li>
            <li Class="PatchOperationConditional">
              <xpath>Defs/FactionDef[defName="PirateYttakin"]/xenotypeSet/xenotypeChances/WVC_Sandycat</xpath>
              <match Class="PatchOperationRemove">
                <xpath>Defs/FactionDef[defName="PirateYttakin"]/xenotypeSet/xenotypeChances/WVC_Sandycat</xpath>
              </match>
            </li>
            <li Class="PatchOperationConditional">
              <xpath>Defs/FactionDef[defName="HoraxCult"]/xenotypeSet</xpath>
              <match Class="PatchOperationAdd">
                <xpath>Defs/FactionDef[defName="HoraxCult"]/xenotypeSet/xenotypeChances</xpath>
                <value>
                  <WVC_Sandycat>0.02</WVC_Sandycat>
                </value>
              </match>
              <nomatch Class="PatchOperationAdd">
                <xpath>Defs/FactionDef[defName="HoraxCult"]</xpath>
                <value>
                  <xenotypeSet Inherit="False">
                    <xenotypeChances>
                      <WVC_Sandycat>0.02</WVC_Sandycat>
                    </xenotypeChances>
                  </xenotypeSet>
                </value>
              </nomatch>
