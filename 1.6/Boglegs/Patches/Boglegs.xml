      <li Class="RebalancePatches.PatchOperationFindModById">
        <mods><li>sarg.alphagenes</li></mods>
        <match Class="PatchOperationAdd">
          <xpath>Defs/XenotypeDef[defName="DV_Bogleg"]/genes</xpath>
          <value><li>AG_WaterStriding</li></value>
        </match>
      </li>
    </operations>
  </Operation>

</Patch>
