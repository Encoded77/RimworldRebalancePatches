    <operations>
      <li Class="RebalancePatches.PatchOperationFindModById">
        <mods><li>wvc.sergkart.races.biotech</li></mods>
        <match Class="PatchOperationAdd">
          <xpath>Defs/XenotypeDef[defName="Stoneborn"]/genes</xpath>
          <value><li>WVC_StoneSkin</li></value>
        </match>
      </li>
    </operations>
  </Operation>

</Patch>
