  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>vqea.sittable</settingKey>
    <operations>
      <li Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="VQEA_AncientHospitalArmchair"]/building</xpath>
        <value>
          <isSittable>true</isSittable>
        </value>
      </li>
      <li Class="PatchOperationAdd">
        <xpath>Defs/ThingDef[defName="VQEA_AncientHospitalBench"]/building</xpath>
        <value>
          <isSittable>true</isSittable>
        </value>
      </li>
    </operations>
  </Operation>
  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>vqea.giantweapons</settingKey>
    <operations>
      <li Class="RebalancePatches.PatchOperationFindModById">
        <mods>
          <li>redmattis.bigsmall.core</li>
        </mods>
        <match Class="PatchOperationSequence">
          <operations>
            <li Class="PatchOperationAdd">
              <xpath>Defs/GeneDef[defName="VQEA_Herculean"]</xpath>
              <value>
                <forcedTraits>
                  <li>
                    <def>BS_Giant</def>
                  </li>
                </forcedTraits>
              </value>
            </li>
            <li Class="PatchOperationAdd">
              <xpath>Defs/GeneDef[defName="VQEA_Enormous"]</xpath>
              <value>
                <forcedTraits>
                  <li>
                    <def>BS_Giant</def>
                  </li>
                </forcedTraits>
              </value>
            </li>
          </operations>
        </match>
      </li>
    </operations>
  </Operation>
  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>vqea.patientgown</settingKey>
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="VQEA_Apparel_PatientGown"]/statBases/ArmorRating_Blunt</xpath>
        <value>
          <ArmorRating_Blunt>0.1</ArmorRating_Blunt>
        </value>
      </li>
    </operations>
  </Operation>
  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.dodge</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="VQEA_Prowess"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="VQEA_Prowess"]/exclusionTags</xpath>
          <value>
            <li>MeleeDodge</li>
          </value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="VQEA_Prowess"]</xpath>
          <value>
            <exclusionTags>
              <li>MeleeDodge</li>
            </exclusionTags>
          </value>
        </nomatch>
      </li>
    </operations>
  </Operation>
