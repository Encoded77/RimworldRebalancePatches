<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.bloodlust</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="VRE_Distressed"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="VRE_Distressed"]/exclusionTags</xpath>
          <value><li>RBP_BloodlustDistressed</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="VRE_Distressed"]</xpath>
          <value><exclusionTags><li>RBP_BloodlustDistressed</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.flirty</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="VRE_Flirty"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="VRE_Flirty"]/exclusionTags</xpath>
          <value><li>RBP_Flirt</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="VRE_Flirty"]</xpath>
          <value><exclusionTags><li>RBP_Flirt</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

</Patch>
