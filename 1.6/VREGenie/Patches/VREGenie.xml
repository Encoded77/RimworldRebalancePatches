<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.bleedrate</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="VRE_Hemophiliac"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="VRE_Hemophiliac"]/exclusionTags</xpath>
          <value><li>RBP_BleedRate</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="VRE_Hemophiliac"]</xpath>
          <value><exclusionTags><li>RBP_BleedRate</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

</Patch>
