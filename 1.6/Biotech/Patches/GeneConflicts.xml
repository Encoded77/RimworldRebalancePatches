<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.hemogen</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="HemogenDrain"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="HemogenDrain"]/exclusionTags</xpath>
          <value><li>HemogenDrain</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="HemogenDrain"]</xpath>
          <value><exclusionTags><li>HemogenDrain</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.deathless</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="Deathless"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="Deathless"]/exclusionTags</xpath>
          <value><li>RBP_Deathless</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="Deathless"]</xpath>
          <value><exclusionTags><li>RBP_Deathless</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

</Patch>
