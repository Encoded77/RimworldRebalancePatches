      <li Class="RebalancePatches.PatchOperationReplaceFromSetting">
        <settingKey>vanilla.genecomplexityprocessor</settingKey>
        <xpath>Defs/ThingDef[defName="GeneProcessor"]/statBases/GeneticComplexityIncrease</xpath>
