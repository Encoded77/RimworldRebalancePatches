<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneticsresearch.consumables</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchProjectDef[defName="RBP_GeneToolkits"]</xpath>
        <match Class="PatchOperationSequence">
          <operations>
            <li Class="PatchOperationAdd">
              <xpath>Defs/ThingDef[defName="AG_GenepackTweaker" or defName="AG_GenepackDisruptor"]</xpath>
              <value>
                <recipeMaker>
                  <researchPrerequisite>RBP_GeneToolkits</researchPrerequisite>
                  <recipeUsers>
                    <li>FabricationBench</li>
                  </recipeUsers>
                  <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
                  <workSkill>Crafting</workSkill>
                  <effectWorking>Smith</effectWorking>
                  <soundWorking>Recipe_Machining</soundWorking>
                  <skillRequirements>
                    <Crafting>6</Crafting>
                  </skillRequirements>
                </recipeMaker>
                <costList>
                  <Neutroamine>4</Neutroamine>
                  <ComponentIndustrial>1</ComponentIndustrial>
                </costList>
              </value>
            </li>
            <li Class="PatchOperationAdd">
              <xpath>Defs/ThingDef[defName="AG_GenepackTweaker" or defName="AG_GenepackDisruptor"]/statBases</xpath>
              <value>
                <WorkToMake>6000</WorkToMake>
              </value>
            </li>
            <li Class="PatchOperationAdd">
              <xpath>Defs/ThingDef[defName="AG_GeneRemover" or defName="AG_Endogenefier" or defName="AG_Xenogenefier"]</xpath>
              <value>
                <recipeMaker>
                  <researchPrerequisite>RBP_GeneToolkits</researchPrerequisite>
                  <recipeUsers>
                    <li>FabricationBench</li>
                  </recipeUsers>
                  <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
                  <workSkill>Crafting</workSkill>
                  <effectWorking>Smith</effectWorking>
                  <soundWorking>Recipe_Machining</soundWorking>
                  <skillRequirements>
                    <Crafting>6</Crafting>
                  </skillRequirements>
                </recipeMaker>
                <costList>
                  <Neutroamine>8</Neutroamine>
                  <ComponentIndustrial>2</ComponentIndustrial>
                </costList>
              </value>
            </li>
            <li Class="PatchOperationAdd">
              <xpath>Defs/ThingDef[defName="AG_GeneRemover" or defName="AG_Endogenefier" or defName="AG_Xenogenefier"]/statBases</xpath>
              <value>
                <WorkToMake>9000</WorkToMake>
              </value>
            </li>
            <li Class="PatchOperationAdd">
              <xpath>Defs/ThingDef[defName="AG_XenotypeNullifier" or defName="AG_XenotypeInjector"]</xpath>
              <value>
                <recipeMaker>
                  <researchPrerequisite>RBP_GeneToolkits</researchPrerequisite>
                  <recipeUsers>
                    <li>FabricationBench</li>
                  </recipeUsers>
                  <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
                  <workSkill>Crafting</workSkill>
                  <effectWorking>Smith</effectWorking>
                  <soundWorking>Recipe_Machining</soundWorking>
                  <skillRequirements>
                    <Crafting>6</Crafting>
                  </skillRequirements>
                </recipeMaker>
                <costList>
                  <Neutroamine>12</Neutroamine>
                  <ComponentSpacer>1</ComponentSpacer>
                </costList>
              </value>
            </li>
            <li Class="PatchOperationAdd">
              <xpath>Defs/ThingDef[defName="AG_XenotypeNullifier" or defName="AG_XenotypeInjector"]/statBases</xpath>
              <value>
                <WorkToMake>12000</WorkToMake>
              </value>
            </li>
            <li Class="PatchOperationAdd">
              <xpath>Defs/ThingDef[defName="AG_ArchoGeneRemover" or defName="AG_ArchoEndogenefier" or defName="AG_ArchoXenogenefier"]</xpath>
              <value>
                <researchPrerequisites>
                  <li>RBP_GeneToolkits</li>
                  <li>Archogenetics</li>
                </researchPrerequisites>
                <recipeMaker>
                  <researchPrerequisites>
                    <li>RBP_GeneToolkits</li>
                    <li>Archogenetics</li>
                  </researchPrerequisites>
                  <recipeUsers>
                    <li>FabricationBench</li>
                  </recipeUsers>
                  <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
                  <workSkill>Crafting</workSkill>
                  <effectWorking>Smith</effectWorking>
                  <soundWorking>Recipe_Machining</soundWorking>
                  <skillRequirements>
                    <Crafting>8</Crafting>
                  </skillRequirements>
                </recipeMaker>
                <costList>
                  <Neutroamine>12</Neutroamine>
                  <ComponentSpacer>2</ComponentSpacer>
                  <ArchiteCapsule>1</ArchiteCapsule>
                </costList>
              </value>
            </li>
            <li Class="PatchOperationAdd">
              <xpath>Defs/ThingDef[defName="AG_ArchoGeneRemover" or defName="AG_ArchoEndogenefier" or defName="AG_ArchoXenogenefier"]/statBases</xpath>
              <value>
                <WorkToMake>18000</WorkToMake>
              </value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>Defs/ThingDef[defName="AG_ArchoXenogenefier"]/statBases/MarketValue</xpath>
              <value><MarketValue>500</MarketValue></value>
            </li>
            <li Class="PatchOperationRemove">
              <xpath>Defs/ThingDef[defName="AG_RandomGeneTool"]/comps/li[@Class="AlphaGenes.CompProperties_RandomItemSpawner"]/items/li[item="AG_GermlineMutator"]</xpath>
            </li>
          </operations>
        </match>
      </li>
    </operations>
  </Operation>

</Patch>
