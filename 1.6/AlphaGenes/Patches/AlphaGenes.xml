<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>genetics.alphagenes</settingKey>
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/QuestScriptDef[defName="AG_OpportunitySite_AbandonedBiotechLab"]/questNameRules/rulesStrings</xpath>
        <value>
          <rulesStrings>
            <li>questName(priority=1)->[biotechlab] [discovered]</li>
            <li>biotechlab->Xenogenetics lab</li>
            <li>biotechlab->Human genetics lab</li>
            <li>biotechlab->Xenogenetic experimentation lab</li>
            <li>biotechlab->Human genetic experimentation lab</li>
            <li>discovered->discovered</li>
            <li>discovered->found</li>
            <li>discovered->located</li>
            <li>discovered->brought to light</li>
            <li>discovered->tracked down</li>
            <li>discovered->unearthed</li>
          </rulesStrings>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>Defs/QuestScriptDef[defName="AG_OpportunitySite_AbandonedBiotechLab"]/questDescriptionRules/rulesStrings</xpath>
        <value>
          <rulesStrings>
            <li>questDescription(askerIsNull==true)->A derelict radio beacon seems to be emitting faint radio signals with a location tracker. By decrypting these signals we have discovered that they seem to be leading to an ancient xenogenetics lab not far from [map_definite]. The site may have some salvageable human genetic technology, so it could be a good idea to investigate it.\n\nWe should be well prepared, as the radio beacon may attract a hostile presence to the lab's location.</li>
          </rulesStrings>
        </value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>Defs/SitePartDef[defName="AG_AbandonedBiotechLab"]/label</xpath>
        <value><label>abandoned xenogenetics lab</label></value>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.firefoam</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="AG_FireObsession"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="AG_FireObsession"]/exclusionTags</xpath>
          <value><li>RBP_FirefoamPyromaniac</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="AG_FireObsession"]</xpath>
          <value><exclusionTags><li>RBP_FirefoamPyromaniac</li></exclusionTags></value>
        </nomatch>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneconflicts.claws</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="AG_ClawedHands"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="AG_ClawedHands"]/exclusionTags</xpath>
          <value><li>RBP_Claws</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="AG_ClawedHands"]</xpath>
          <value><exclusionTags><li>RBP_Claws</li></exclusionTags></value>
        </nomatch>
      </li>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="AG_CrabClaw"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="AG_CrabClaw"]/exclusionTags</xpath>
          <value><li>RBP_Claws</li></value>
        </match>
        <nomatch Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="AG_CrabClaw"]</xpath>
          <value><exclusionTags><li>RBP_Claws</li></exclusionTags></value>
        </nomatch>
      </li>
      <li Class="PatchOperationConditional">
        <xpath>Defs/GeneDef[defName="AG_VFEI_PneumaticClaw"]/exclusionTags</xpath>
        <match Class="PatchOperationAdd">
          <xpath>Defs/GeneDef[defName="AG_VFEI_PneumaticClaw"]/exclusionTags</xpath>
          <value><li>RBP_Claws</li></value>
        </match>
        <nomatch Class="PatchOperationConditional">
          <xpath>Defs/GeneDef[defName="AG_VFEI_PneumaticClaw"]</xpath>
          <match Class="PatchOperationAdd">
            <xpath>Defs/GeneDef[defName="AG_VFEI_PneumaticClaw"]</xpath>
            <value><exclusionTags><li>RBP_Claws</li></exclusionTags></value>
          </match>
        </nomatch>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>alphagenes.beautyrename</settingKey>
    <operations>
      <li Class="RebalancePatches.PatchOperationFindModById">
        <mods>
          <li>wvc.sergkart.races.biotech</li>
        </mods>
        <match Class="PatchOperationReplace">
          <xpath>Defs/GeneDef[defName="AG_Beauty_Angelic"]/label</xpath>
          <value><label>uncanny beauty</label></value>
        </match>
      </li>
    </operations>
  </Operation>

</Patch>
