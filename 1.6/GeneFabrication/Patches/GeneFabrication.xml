<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>geneticsresearch.genefab</settingKey>
    <operations>
      <li Class="PatchOperationConditional">
        <xpath>Defs/ResearchTabDef[defName="RBP_GeneticsTab"]</xpath>
        <match Class="PatchOperationSequence">
          <operations>
            <li Class="PatchOperationReplace">
              <xpath>Defs/ResearchProjectDef[defName="GeneFabrication"]/label</xpath>
              <value><label>gene fabrication</label></value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>Defs/ResearchProjectDef[defName="GeneFabrication"]/description</xpath>
              <value><description>Build a gene fabrication bench that synthesises genepacks directly from neutroamine, drawing on archite capsules for archite-grade genes. Any gene your colony has records of can be produced to order, rather than waiting on traders, quest rewards and whatever survives in ancient ruins.</description></value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>Defs/ResearchProjectDef[defName="GeneFabrication"]/baseCost</xpath>
              <value><baseCost>8000</baseCost></value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>Defs/ResearchProjectDef[defName="GeneFabrication"]/prerequisites</xpath>
              <value>
                <prerequisites>
                  <li>Archogenetics</li>
                </prerequisites>
              </value>
            </li>
            <li Class="PatchOperationAdd">
              <xpath>Defs/ResearchProjectDef[defName="GeneFabrication"]</xpath>
              <value>
                <tab>RBP_GeneticsTab</tab>
                <requiredResearchBuilding>HiTechResearchBench</requiredResearchBuilding>
              </value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>Defs/ResearchProjectDef[defName="GeneFabrication"]/techLevel</xpath>
              <value><techLevel>Ultra</techLevel></value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>Defs/ResearchProjectDef[defName="GeneFabrication"]/researchViewX</xpath>
              <value><researchViewX>5</researchViewX></value>
            </li>
            <li Class="PatchOperationReplace">
              <xpath>Defs/ResearchProjectDef[defName="GeneFabrication"]/researchViewY</xpath>
              <value><researchViewY>2.60</researchViewY></value>
            </li>
          </operations>
        </match>
      </li>
    </operations>
  </Operation>

</Patch>
