<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>odyssey.shuttle</settingKey>
    <operations>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="PassengerShuttle"]/comps/li[@Class="CompProperties_Refuelable"]/fuelCapacity</xpath>
        <value><fuelCapacity>2000</fuelCapacity></value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="PassengerShuttle"]/comps/li[@Class="CompProperties_Refuelable"]/initialConfigurableTargetFuelLevel</xpath>
        <value><initialConfigurableTargetFuelLevel>2000</initialConfigurableTargetFuelLevel></value>
      </li>
      <li Class="PatchOperationReplace">
        <xpath>Defs/ThingDef[defName="PassengerShuttle"]/comps/li[@Class="CompProperties_Transporter"]/massCapacity</xpath>
        <value><massCapacity>2000</massCapacity></value>
      </li>
    </operations>
  </Operation>

  <Operation Class="RebalancePatches.PatchOperationIfEnabled">
    <settingKey>xenotypes.odyssey</settingKey>
    <operations>
      <li Class="PatchOperationAdd">
        <xpath>Defs/FactionDef[defName="Salvagers"]/xenotypeSet/xenotypeChances</xpath>
        <value>
          <DV_Halffoot MayRequire="det.halffoot">0.05</DV_Halffoot>
          <Zohar MayRequire="rimsenal.zohar">0.04</Zohar>
          <Askbarn MayRequire="rimsenal.askbarn">0.04</Askbarn>
          <Uredd MayRequire="rimsenal.askbarn">0.04</Uredd>
          <Harana MayRequire="rimsenal.harana">0.04</Harana>
          <DV_Venator MayRequire="det.venators">0.04</DV_Venator>
          <DV_Keshig MayRequire="det.keshig">0.04</DV_Keshig>
          <AG_Fleetkind MayRequire="sarg.alphagenes">0.04</AG_Fleetkind>
        </value>
      </li>
      <li Class="PatchOperationAdd">
        <xpath>Defs/FactionDef[defName="TradersGuild"]/xenotypeSet/xenotypeChances</xpath>
        <value>
          <AG_Fleetkind MayRequire="sarg.alphagenes">0.05</AG_Fleetkind>
        </value>
      </li>
    </operations>
  </Operation>

</Patch>
